---
import Layout from '../layouts/Layout.astro';
import TeamCard from '../components/TeamCard.astro';
import { SITE_DESCRIPTION, SITE_PHONE, SITE_EMAIL, SITE_ADDRESS, SITE_MAP_EMBED_URL } from '../consts';
import { coreTeam, collaborators, teamMembers } from '../data/team';
---

<Layout description={SITE_DESCRIPTION}>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-charcoal" id="hero">
    <!-- Background image -->
    <div class="absolute inset-0 z-0">
      <img src="/images/hero-bg.jpg" alt="" class="w-full h-full object-cover !rounded-none opacity-45" />
      <div class="absolute inset-0 bg-gradient-to-b from-[#1a1a1a99] via-[#1a1a1a33] to-[#1a1a1ab3]"></div>
      <div class="absolute inset-0 bg-gradient-to-br from-[rgba(198,156,63,0.08)] to-transparent"></div>
    </div>

    <!-- Floating shapes -->
    <div class="absolute w-[500px] h-[500px] rounded-full -top-[10%] -right-[5%] z-[1] pointer-events-none animate-float bg-[radial-gradient(circle,rgba(198,156,63,0.12),transparent_70%)]"></div>
    <div class="absolute w-[350px] h-[350px] rounded-full bottom-[10%] -left-[5%] z-[1] pointer-events-none animate-float-delayed bg-[radial-gradient(circle,rgba(61,107,94,0.08),transparent_70%)]"></div>
    <div class="absolute w-[200px] h-[200px] rounded-full top-[30%] right-[20%] z-[1] pointer-events-none animate-float-slow bg-[radial-gradient(circle,rgba(198,156,63,0.06),transparent_70%)]"></div>

    <div class="relative z-[2] max-w-[1200px] mx-auto px-6 pt-32 pb-20 max-md:pt-28 max-md:pb-16">
      <div>
        <span class="inline-block text-[0.72rem] font-semibold tracking-[0.2em] uppercase text-gold-light mb-8 opacity-85">Kraków · Poradnia chrześcijańska</span>
        <h1 class="text-white font-bold tracking-tight mb-6 leading-[1.08]">
          Profesjonalna pomoc<br />
          na <em class="bg-gradient-to-br from-gold-light to-gold bg-clip-text text-transparent italic">drodze</em> do zdrowia
        </h1>
        <p class="text-[clamp(0.95rem,1.5vw,1.1rem)] text-white/65 leading-7 max-w-[480px] mb-10">
          Psychoterapia, coaching i poradnictwo w oparciu<br class="hidden sm:inline" />
          o wartości chrześcijańskie. Towarzyszymy Ci<br class="hidden sm:inline" />
          w trudnych momentach życia.
        </p>
        <div class="flex gap-4 flex-wrap">
          <a href="#zespol" class="inline-flex items-center gap-2 px-7 py-3 rounded-full font-semibold text-[0.88rem] bg-gold text-charcoal hover:bg-gold-light transition-all duration-300 shadow-gold">
            Poznaj nasz zespół
          </a>
          <a href="#kontakt" class="inline-flex items-center gap-2 px-7 py-3 rounded-full font-semibold text-[0.88rem] text-white/90 border border-white/20 hover:bg-white/8 hover:border-white/35 transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Zadzwoń
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-[2] max-sm:hidden">
      <div class="w-px h-12 bg-gradient-to-b from-transparent via-white/30 to-transparent animate-pulse"></div>
    </div>
  </section>

  <!-- ═══════════════ O NAS ═══════════════ -->
  <section class="py-24 max-md:py-16 overflow-hidden relative" id="o-nas">
    <div class="absolute w-[600px] h-[600px] rounded-full -top-[30%] -right-[20%] bg-[radial-gradient(circle,var(--color-gold-glow),transparent_70%)] pointer-events-none"></div>
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="max-w-[700px] mx-auto text-center reveal">
        <span class="inline-flex items-center gap-3 text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-gold-dark mb-5 before:content-[''] before:w-8 before:h-[1.5px] before:bg-gold">O nas</span>
        <h2 class="mb-8">Pomagamy ludziom<br />odnaleźć <em class="italic text-gold">równowagę</em></h2>
        <div class="text-[1.05rem] leading-[1.85] text-slate-custom space-y-4">
          <p>
            Skupiamy się na <strong class="text-charcoal font-semibold">indywidualnym podejściu</strong> do każdej osoby —
            uwzględniając kontekst rodzinny, społeczny i zawodowy. Postrzegamy człowieka
            jako <strong class="text-charcoal font-semibold">całość fizyczną, psychiczną i duchową</strong>.
          </p>
          <p>
            W naszych działaniach kierujemy się wartościami chrześcijańskimi
            i nauką Jezusa Chrystusa. Jako zespół dokładamy wszelkich starań, by zarówno
            w pracy, jak i w życiu osobistym kierować się oddaniem i posłuszeństwem Bogu.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ USŁUGI ═══════════════ -->
  <section class="py-24 max-md:py-16 bg-cream-warm">
    <div class="max-w-[1200px] mx-auto px-6">
      <span class="inline-flex items-center gap-3 text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-gold-dark mb-5 reveal before:content-[''] before:w-8 before:h-[1.5px] before:bg-gold">Jak pomagamy</span>
      <h2 class="mb-12 max-w-[500px] reveal">
        Kompleksowe wsparcie<br />w wielu obszarach życia
      </h2>

      <div class="grid grid-cols-4 gap-5 max-lg:grid-cols-2 max-sm:grid-cols-1">
        {[
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`, title: 'Psychoterapia', desc: 'Indywidualna i grupowa terapia dla dorosłych i młodzieży — CBT, terapia systemowa, Gestalt.' },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`, title: 'Poradnictwo rodzinne', desc: 'Konsultacje małżeńskie i rodzinne, wsparcie w kryzysach relacyjnych, wychowawczych i emocjonalnych.' },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>`, title: 'Coaching i mentoring', desc: 'Odkrywanie talentów, rozwój osobisty i zawodowy, budowanie świadomości i przywództwa.' },
          { icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>`, title: 'Interwencja kryzysowa', desc: 'Pomoc w kryzysach egzystencjalnych, rozwojowych, duchowych i sytuacyjnych — szybko i skutecznie.' },
        ].map(({ icon, title, desc }, i) => (
          <div class:list={[
            'reveal glass-card p-8 flex flex-col bg-white/55 backdrop-blur-md border border-white/60 rounded-2xl',
            `reveal-delay-${i + 1}`,
          ]}>
            <div class="w-11 h-11 flex items-center justify-center rounded-lg bg-gold-glow text-gold-dark mb-5" set:html={icon} />
            <h3 class="text-base mb-2">{title}</h3>
            <p class="text-[0.85rem] text-muted leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════ ZESPÓŁ ═══════════════ -->
  <section class="py-24 max-md:py-16 overflow-hidden relative" id="zespol">
    <div class="absolute w-[500px] h-[500px] rounded-full -bottom-[10%] -left-[15%] bg-[radial-gradient(circle,var(--color-gold-glow),transparent_70%)] pointer-events-none"></div>
    <div class="max-w-[1200px] mx-auto px-6">
      <span class="inline-flex items-center gap-3 text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-gold-dark mb-5 reveal before:content-[''] before:w-8 before:h-[1.5px] before:bg-gold">Zespół</span>
      <h2 class="mb-4 reveal">
        Specjaliści, którym <em class="italic text-gold">możesz zaufać</em>
      </h2>
      <p class="text-muted text-base max-w-[520px] mb-12 reveal">
        Każdy z nas łączy profesjonalne wykształcenie z osobistą wiarą — bo najlepsza pomoc uwzględnia całego człowieka.
      </p>

      <div class="grid grid-cols-3 gap-5 mb-12 max-lg:grid-cols-2 max-sm:grid-cols-1 max-sm:max-w-[360px] max-sm:mx-auto">
        {coreTeam.map((m, i) => (
          <TeamCard member={m} index={i} />
        ))}
      </div>

      {collaborators.length > 0 && (
        <div class="pt-8 border-t border-border reveal">
          <span class="inline-flex items-center gap-3 text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-gold-dark mb-6 before:content-[''] before:w-8 before:h-[1.5px] before:bg-gold">Współpracujący</span>
          <div class="flex flex-wrap gap-5">
            {collaborators.map((m, i) => (
              <div class:list={['reveal', `reveal-delay-${(i % 4) + 1}`]}>
                <a
                  href={`/zespol/${m.slug}`}
                  class:list={[
                    'group flex items-center gap-6 px-6 py-5 bg-white/55 backdrop-blur-md border border-white/60 rounded-2xl',
                    'no-underline text-charcoal cursor-pointer min-w-[320px] max-w-[480px]',
                    'transition-all duration-400 hover:-translate-y-1 hover:shadow-lg hover:border-border-warm',
                    'relative overflow-hidden h-full',
                  ]}
                >
                <div class="absolute inset-0 bg-gradient-to-b from-gold-glow to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="relative w-[80px] h-[80px] shrink-0 z-[1]">
                  <div class="absolute -inset-[4px] rounded-full border-[1.5px] border-gold-light group-hover:border-gold transition-all duration-300 pointer-events-none"></div>
                  <div class="w-full h-full rounded-full overflow-hidden">
                    <img
                      src={m.photo}
                      alt={m.name}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      loading="lazy"
                    />
                  </div>
                </div>
                <div class="flex-1 z-[1]">
                  <h3 class="text-[1rem] font-semibold mb-0.5">{m.name}</h3>
                  <p class="text-[0.8rem] text-muted leading-snug mb-2">{m.role}</p>
                  <span class="inline-flex items-center gap-1 text-[0.75rem] font-semibold uppercase tracking-wide text-gold-dark group-hover:gap-2 group-hover:text-gold transition-all duration-150">
                    Profil
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </span>
                </div>
              </a>
            </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════ KONTAKT ═══════════════ -->
  <section class="py-24 max-md:py-16 bg-cream-warm" id="kontakt">
    <div class="max-w-[1200px] mx-auto px-6">
      <div class="grid grid-cols-[1fr_1.3fr] gap-10 items-stretch reveal max-md:grid-cols-1">
        <div>
          <span class="inline-flex items-center gap-3 text-[0.68rem] font-semibold tracking-[0.2em] uppercase text-gold-dark mb-5 before:content-[''] before:w-8 before:h-[1.5px] before:bg-gold">Kontakt</span>
          <h2 class="mb-4">Porozmawiajmy</h2>
          <p class="text-muted text-[0.95rem] mb-8">
            Jeśli szukasz wsparcia lub masz pytania — skontaktuj się z nami.
            Chętnie pomożemy dobrać odpowiedniego specjalistę.
          </p>

          <div class="flex flex-col gap-4">
            <a href={`tel:+48${SITE_PHONE.replace(/\s/g, '')}`} class="flex items-center gap-4 py-4 px-5 bg-white border border-border rounded-xl no-underline text-charcoal transition-all duration-300 hover:border-border-warm hover:shadow-sm hover:translate-x-1">
              <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gold-glow text-gold-dark shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <span class="block text-[0.7rem] font-semibold tracking-wider uppercase text-muted mb-px">Telefon</span>
                <span class="text-[0.9rem] font-medium">{SITE_PHONE}</span>
              </div>
            </a>

            <a href={`mailto:${SITE_EMAIL}`} class="flex items-center gap-4 py-4 px-5 bg-white border border-border rounded-xl no-underline text-charcoal transition-all duration-300 hover:border-border-warm hover:shadow-sm hover:translate-x-1">
              <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gold-glow text-gold-dark shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              </div>
              <div>
                <span class="block text-[0.7rem] font-semibold tracking-wider uppercase text-muted mb-px">E-mail</span>
                <span class="text-[0.9rem] font-medium">{SITE_EMAIL}</span>
              </div>
            </a>

            <div class="flex items-center gap-4 py-4 px-5 bg-white border border-border rounded-xl">
              <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-gold-glow text-gold-dark shrink-0">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <span class="block text-[0.7rem] font-semibold tracking-wider uppercase text-muted mb-px">Adres</span>
                <span class="text-[0.9rem] font-medium">{SITE_ADDRESS}</span>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-2xl overflow-hidden shadow-md min-h-[380px] max-md:min-h-[300px]">
          <iframe
            src={SITE_MAP_EMBED_URL}
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lokalizacja poradni"
          ></iframe>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0) scale(1); }
    33% { transform: translate(20px, -30px) scale(1.05); }
    66% { transform: translate(-15px, 15px) scale(0.97); }
  }

  .animate-float { animation: float 12s infinite ease-in-out; }
  .animate-float-delayed { animation: float 12s infinite ease-in-out; animation-delay: -4s; }
  .animate-float-slow { animation: float 12s infinite ease-in-out; animation-delay: -8s; }
</style>
