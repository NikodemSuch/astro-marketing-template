---
import { SITE_TITLE, SITE_ADDRESS, SITE_PHONE, SITE_EMAIL } from '../consts';
const year = new Date().getFullYear();
---

<footer class="bg-charcoal text-white/50 text-sm pt-12">
  <div class="max-w-[1200px] mx-auto px-6 flex justify-between gap-8 pb-10 border-b border-white/8 max-md:flex-col">
    <div>
      <img src="/images/logo.png" alt={SITE_TITLE} class="h-9 w-auto mb-3 brightness-[10] opacity-70" />
      <p class="leading-relaxed max-w-[240px]">
        Profesjonalna pomoc psychologiczna<br/>z wartościami chrześcijańskimi.
      </p>
    </div>
    <div class="flex flex-col gap-2">
      <a href="/#o-nas" class="text-white/60 hover:text-gold-light transition-colors duration-150">O nas</a>
      <a href="/#zespol" class="text-white/60 hover:text-gold-light transition-colors duration-150">Zespół</a>
      <a href="/#kontakt" class="text-white/60 hover:text-gold-light transition-colors duration-150">Kontakt</a>
    </div>
    <div class="flex flex-col gap-2 md:text-right max-md:text-left">
      <a href={`tel:+48${SITE_PHONE.replace(/\s/g, '')}`} class="text-white/60 hover:text-gold-light transition-colors duration-150">{SITE_PHONE}</a>
      <a href={`mailto:${SITE_EMAIL}`} class="text-white/60 hover:text-gold-light transition-colors duration-150">{SITE_EMAIL}</a>
      <span>{SITE_ADDRESS}</span>
    </div>
  </div>
  <div class="max-w-[1200px] mx-auto px-6 py-6">
    <p class="text-xs opacity-40">&copy; {year} {SITE_TITLE}</p>
  </div>
</footer>
