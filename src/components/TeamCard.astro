---
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
  index?: number;
}

const { member, index = 0 } = Astro.props;
const delayClass = `reveal-delay-${(index % 4) + 1}`;
---

<div class:list={['reveal h-full', delayClass]}>
  <a
    href={`/zespol/${member.slug}`}
    class:list={[
      'group flex flex-col items-center text-center px-6 pt-8 pb-6',
      'bg-white/55 backdrop-blur-md border border-white/60 rounded-2xl',
      'no-underline text-charcoal cursor-pointer',
      'transition-all duration-400 hover:-translate-y-2 hover:shadow-lg hover:border-border-warm',
      'relative overflow-hidden h-full',
    ]}
  >
  {/* Top glow on hover */}
  <div class="absolute inset-0 bg-gradient-to-b from-gold-glow to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

  {/* Photo with ring */}
  <div class="relative w-[120px] h-[120px] mb-6 z-[1]">
    <div class="absolute -inset-[5px] rounded-full border-2 border-gold-light group-hover:border-gold group-hover:-inset-[7px] group-hover:border-[2.5px] transition-all duration-300 pointer-events-none"></div>
    <div class="w-full h-full rounded-full overflow-hidden">
      <img
        src={member.photo}
        alt={member.name}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  </div>

  {/* Body */}
  <div class="flex-1 z-[1]">
    <h3 class="text-[1.05rem] font-semibold mb-1">{member.name}</h3>
    <p class="text-[0.8rem] text-muted leading-snug">{member.role}</p>
  </div>

  {/* CTA */}
  <div class="mt-5 z-[1]">
    <span class="inline-flex items-center gap-1 text-[0.78rem] font-semibold uppercase tracking-wide text-gold-dark group-hover:gap-2 group-hover:text-gold transition-all duration-150">
      Profil
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </span>
  </div>
</a>
</div>
