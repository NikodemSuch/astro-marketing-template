---
import { SITE_TITLE } from '../consts';

const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';

const navLinks = [
  { href: '/#o-nas', label: 'O nas' },
  { href: '/#zespol', label: 'Zespół' },
  { href: '/#kontakt', label: 'Kontakt' },
];
---

<header
  id="site-header"
  class:list={[
    'group/header top-0 z-50 transition-all duration-300',
    isHome
      ? 'fixed w-full bg-transparent border-b border-transparent'
      : 'sticky bg-cream border-b border-border',
  ]}
>
  <nav class="max-w-[1200px] mx-auto px-6 flex items-center justify-between h-[72px]">
    <a href="/" aria-label="Strona główna" class="group relative z-[110]">
      <img
        id="nav-logo"
        src="/images/logo.png"
        alt={SITE_TITLE}
        class:list={[
          'h-[42px] w-auto transition-all duration-300',
          isHome ? 'brightness-[10] group-data-[scrolled=true]/header:brightness-100' : '',
        ]}
      />
    </a>

    <button
      id="nav-toggle"
      class="hidden max-md:block bg-transparent border-none cursor-pointer w-8 h-8 relative z-[110]"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span id="bar1" class:list={[
        'block w-[22px] h-[1.5px] absolute left-[5px] top-[11px] transition-all duration-300',
        isHome ? 'bg-white group-data-[scrolled=true]/header:bg-charcoal' : 'bg-charcoal',
      ]}></span>
      <span id="bar2" class:list={[
        'block w-[22px] h-[1.5px] absolute left-[5px] top-[19px] transition-all duration-300',
        isHome ? 'bg-white group-data-[scrolled=true]/header:bg-charcoal' : 'bg-charcoal',
      ]}></span>
    </button>

    <ul id="nav-links" class="flex list-none gap-0 max-md:absolute max-md:top-full max-md:left-0 max-md:right-0 max-md:flex-col max-md:px-2 max-md:pt-4 max-md:pb-6 max-md:bg-cream max-md:border-b max-md:border-border max-md:shadow-sm max-md:opacity-0 max-md:pointer-events-none max-md:transition-all max-md:duration-300 max-md:-translate-y-2 z-[100]">
      {navLinks.map(({ href, label }) => (
        <li class="max-md:border-b max-md:border-border max-md:last:border-none">
          <a
            href={href}
            class:list={[
              'nav-link relative block px-4 py-2 max-md:py-4 max-md:px-6 text-[0.88rem] font-medium transition-all duration-150',
              'md:rounded-full', // only rounded on desktop
              isHome
                ? 'md:text-white md:hover:bg-white/12 md:hover:text-white md:nav-text-shadow group-data-[scrolled=true]/header:md:text-charcoal group-data-[scrolled=true]/header:md:hover:text-gold-dark group-data-[scrolled=true]/header:md:![text-shadow:none]'
                : 'md:text-charcoal md:hover:text-gold-dark',
              // Force mobile styles (overriding the transparency/white text of home page header when open)
              'max-md:!text-charcoal max-md:hover:!text-gold-dark max-md:data-[active=true]:!text-gold-dark max-md:!bg-transparent max-md:![text-shadow:none]',
              // Active State Underline (Desktop only via md:...)
              'md:after:content-[\'\'] md:after:absolute md:after:bottom-1.5 md:after:left-4 md:after:right-4 md:after:h-[2px] md:after:bg-gold md:after:rounded-full md:after:opacity-0 md:after:transition-opacity md:after:duration-300 md:data-[active=true]:after:opacity-100',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  const header = document.getElementById('site-header');
  const logo = document.getElementById('nav-logo');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const isHome = header?.classList.contains('fixed');

  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('!opacity-100');
    links?.classList.toggle('!pointer-events-auto');
    links?.classList.toggle('!translate-y-0');
    document.body.classList.toggle('overflow-hidden');
    
    if (open) {
      bar1!.style.transform = 'rotate(45deg)';
      bar1!.style.top = '15px';
      bar2!.style.transform = 'rotate(-45deg)';
      bar2!.style.top = '15px';
    } else {
      bar1!.style.transform = '';
      bar1!.style.top = '11px';
      bar2!.style.transform = '';
      bar2!.style.top = '19px';
    }
    toggle.setAttribute('aria-expanded', String(!!open));
  });

  links?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      links.classList.remove('!opacity-100', '!pointer-events-auto', '!translate-y-0');
      document.body.classList.remove('overflow-hidden');
      bar1!.style.transform = '';
      bar1!.style.top = '11px';
      bar2!.style.transform = '';
      bar2!.style.top = '19px';
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  if (isHome) {
    const onScroll = () => {
      const scrolled = window.scrollY > 60;
      if (scrolled) {
        header?.classList.add('!bg-cream/92', 'backdrop-blur-md', '!border-border', 'shadow-sm');
        header?.setAttribute('data-scrolled', 'true');
      } else {
        header?.classList.remove('!bg-cream/92', 'backdrop-blur-md', '!border-border', 'shadow-sm');
        header?.setAttribute('data-scrolled', 'false');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  // Scrollspy logic
  const sections = document.querySelectorAll('section[id]');
  const navItems = document.querySelectorAll('.nav-link');

  const spyScroll = () => {
    let current = '';
    const scrollY = window.scrollY;

    sections.forEach((section) => {
      const el = section as HTMLElement;
      const sectionTop = el.offsetTop - 150;

      if (scrollY >= sectionTop) {
        current = el.getAttribute('id') || '';
      }
    });

    // Handle bottom of page edge-case for the last section (usually contact)
    if (window.innerHeight + Math.round(scrollY) >= document.body.offsetHeight - 50) {
      if (sections.length > 0) {
        current = sections[sections.length - 1].getAttribute('id') || '';
      }
    }

    navItems.forEach((link) => {
      link.removeAttribute('data-active');
      if (current && link.getAttribute('href') === `/#${current}`) {
        link.setAttribute('data-active', 'true');
      }
    });
  };

  if (navItems.length > 0 && sections.length > 0) {
    window.addEventListener('scroll', spyScroll, { passive: true });
    setTimeout(spyScroll, 100);
  }
</script>

<style>
  .nav-text-shadow {
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 0, 0, 0.15);
  }
</style>
